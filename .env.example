# Telegram Bot Token (required)
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Chat ID for automated daily scores (default: @natsdc)
CHAT_ID=@natsdc

# Timezone for scheduling (default: America/Chicago)
TIMEZONE=America/Chicago

# Daily post time for automated scores in HH:MM format (default: 10:00)
DAILY_POST_TIME=10:00

# Leave calculator false-positive rate tolerance (default: 0.05)
LEAVE_FP_RATE=0.05

# Health check server configuration
HEALTHCHECK_PORT=8000
HEALTHCHECK_HOST=0.0.0.0
